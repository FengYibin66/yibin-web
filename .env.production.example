# ──────────────────────────────────────────────────────────────
# Production Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy to .env.production on CVM and fill in all CHANGE_ME values
# DO NOT commit .env.production to git

NODE_ENV=production
ENV=production

# ──────────────────────────────────────────────────────────────
# Database & Cache
# ──────────────────────────────────────────────────────────────

# MySQL (used by Portal and Auto-Wechat)
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_PASSWORD=CHANGE_ME_WECHAT_PASSWORD
DATABASE_URL=mysql://wechat:CHANGE_ME_WECHAT_PASSWORD@tcp(mysql:3306)/wechat_ai?parseTime=true&loc=UTC&charset=utf8mb4

# Redis (used by Auto-Wechat worker queue)
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────────────────────
# Portal (Hono Backend)
# ──────────────────────────────────────────────────────────────

# Server
PORT=3001
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
CLIENT_ORIGIN=https://www.yibinfeng.com

# Portal Database (if using separate DB)
PORTAL_DATABASE_URL=

# ──────────────────────────────────────────────────────────────
# Auto-Wechat API (Go Backend)
# ──────────────────────────────────────────────────────────────

API_PORT=8080
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY
LOG_LEVEL=info

# Session & Security
SESSION_COOKIE_NAME=session_id
SESSION_TTL=24h
SESSION_SECURE=true
SESSION_SAME_SITE=Lax
SECRET_KEY=CHANGE_ME_SECRET_KEY_32_CHARS_MIN
STUB_PIPELINE=false

# CORS (for API requests from frontend)
CORS_ALLOWED_ORIGINS=https://www.yibinfeng.com,https://resume.yibinfeng.com,https://mpauto.yibinfeng.com

# Public API Base URL
# Media URL endpoint: https://mpauto.yibinfeng.com/api/v1/public/media/{id}
PUBLIC_API_BASE_URL=https://mpauto.yibinfeng.com
WECHAT_READ_SOURCE_URL=https://fengyibin66.github.io/

# ──────────────────────────────────────────────────────────────
# LLM Service (Python FastAPI)
# ──────────────────────────────────────────────────────────────

LLM_SERVICE_URL=http://llm-service:8090
LLM_INVOKE_TIMEOUT=10m
LLM_REQUEST_TIMEOUT_SECONDS=600

# Dashscope (Alibaba Qwen)
DASHSCOPE_API_KEY=CHANGE_ME_DASHSCOPE_API_KEY
LLM_MODEL_FAST=qwen-plus
LLM_MODEL_SMART=qwen-max
LLM_MODEL_LAYOUT=qwen-max
LLM_MAX_OUTPUT_TOKENS_LAYOUT=32768

# Image Generation
IMAGE_MODEL=wanx2.1-t2i-turbo
IMAGE_SIZE=1280*720

# ──────────────────────────────────────────────────────────────
# WeChat (公众号配置)
# ──────────────────────────────────────────────────────────────

WECHAT_APP_ID=CHANGE_ME_WECHAT_APP_ID
WECHAT_APP_SECRET=CHANGE_ME_WECHAT_APP_SECRET
WECHAT_ORIGINAL_ID=CHANGE_ME_WECHAT_ORIGINAL_ID
WECHAT_ACCOUNT_TYPE=subscription
WECHAT_ACCOUNT_SUBJECT=personal
WECHAT_CERTIFIED=false
WECHAT_IP_WHITELIST=

# WeChat Message Callback (for message receiving)
# Should match Nginx routing: mpauto.yibinfeng.com/api/v1/wechat/callback
WECHAT_CALLBACK_URL=https://mpauto.yibinfeng.com/api/v1/wechat/callback

# ──────────────────────────────────────────────────────────────
# Tencent Cloud (COS 对象存储)
# ──────────────────────────────────────────────────────────────

TENCENT_SECRET_ID=CHANGE_ME_TENCENT_SECRET_ID
TENCENT_SECRET_KEY=CHANGE_ME_TENCENT_SECRET_KEY
COS_BUCKET=CHANGE_ME_BUCKET_NAME
COS_REGION=ap-hongkong

# ──────────────────────────────────────────────────────────────
# Content Collection Settings
# ──────────────────────────────────────────────────────────────

COLLECT_DAYS=2
COLLECT_MIN_ARTICLES=5

# ──────────────────────────────────────────────────────────────
# Enterprise WeChat (企业微信，可选)
# ──────────────────────────────────────────────────────────────

WECOM_WEBHOOK_URL=

# ──────────────────────────────────────────────────────────────
# SSL / HTTPS
# ──────────────────────────────────────────────────────────────
# Nginx 容器已挂载 /etc/letsencrypt（从 CVM 主机）
# 证书路径（Nginx 容器内）:
# - /etc/letsencrypt/live/www.yibinfeng.com/fullchain.pem
# - /etc/letsencrypt/live/mpauto.yibinfeng.com/fullchain.pem
# - /etc/letsencrypt/live/resume.yibinfeng.com/fullchain.pem
# 由 certbot 自动管理（CVM 定时任务续期）

SSL_CERT_PATH=/etc/letsencrypt/live/www.yibinfeng.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/www.yibinfeng.com/privkey.pem

# ──────────────────────────────────────────────────────────────
# Frontend Environment Variables (读取示例)
# ──────────────────────────────────────────────────────────────
# Portal Frontend: apps/portal/client/vite.config.ts
# - VITE_API_BASE_URL=/api (Nginx proxy 同源)
#
# Resume Frontend: apps/resume/app.config.ts (可选)
#
# Auto-Wechat Frontend: apps/auto-wechat/frontend/vite.config.ts
# - VITE_API_BASE_URL=/api/v1 (相对路径，Nginx 代理)

# ──────────────────────────────────────────────────────────────
# Docker Compose Service Names (internal only, do not change)
# ──────────────────────────────────────────────────────────────
# Services are networked via 'yibin-net' bridge and resolve by container name:
# - mysql:3306
# - redis:6379
# - portal-server:3001
# - auto-wechat-api:8080
# - llm-service:8090
# - nginx:80/443 (external, listening on CVM public IP)

# ──────────────────────────────────────────────────────────────
# Deployment Verification
# ──────────────────────────────────────────────────────────────
# After deploying, verify each service:
#
# Portal:        curl -H "Host: www.yibinfeng.com" http://localhost/api/health
# Resume:        curl -H "Host: resume.yibinfeng.com" http://localhost/
# Auto-Wechat:   curl -H "Host: mpauto.yibinfeng.com" http://localhost/api/v1/health
#
# All via HTTPS:
# curl https://www.yibinfeng.com/api/health
# curl https://resume.yibinfeng.com/
# curl https://mpauto.yibinfeng.com/api/v1/health
