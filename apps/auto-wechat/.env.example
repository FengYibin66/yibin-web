# 环境配置模板 — 复制为 .env.development 后填写真实值
# .env.development 已 gitignore
#
# 环境对照：
#   本地开发     → 复制本文件为 .env.development（见下方 PUBLIC_API_BASE_URL）
#   生产服务器   → 复制 .env.production.example 为 .env.development（服务器沿用此文件名）
#   微信扫码预览 → 临时覆盖 PUBLIC_API_BASE_URL（见 .env.local.ngrok.example）

ENV=development

# ─── Go API ───
API_PORT=8080
ADMIN_API_KEY=
SESSION_COOKIE_NAME=session_id
SESSION_TTL=24h
SESSION_SECURE=false
SESSION_SAME_SITE=Lax
# 生产经 Nginx 同源 /api 时浏览器可不依赖 CORS；直连 :8080 调试时再配
# CORS_ALLOWED_ORIGINS=https://yibinfeng.com
CORS_ALLOWED_ORIGINS=
LOG_LEVEL=info
WECHAT_READ_SOURCE_URL=https://fengyibin66.github.io/
# 媒体 URL、微信预览、阅读原文汇总页根地址（不含 /api/v1）
# 本地开发：http://localhost:8080（配合 frontend/vite.config.ts 的 /api 代理）
# 生产：    https://你的域名（与 Nginx server_name 一致）
PUBLIC_API_BASE_URL=http://localhost:8080

# ─── 数据库 & Redis ───
DATABASE_URL=mysql://wechat:change_me@tcp(localhost:3307)/wechat_ai?parseTime=true&loc=UTC&charset=utf8mb4
REDIS_URL=redis://localhost:6379/0

# ─── 资讯采集（worker 读取）───
COLLECT_DAYS=2
COLLECT_MIN_ARTICLES=5

# ─── LLM 薄服务（llm-service 读取）───
LLM_SERVICE_URL=http://localhost:8090
LLM_INVOKE_TIMEOUT=10m
DASHSCOPE_API_KEY=
# fast：排序/富化/质检/matcher — 纯文本端点（qwen-plus / qwen-turbo）
# 勿用 qwen3.7-plus：多模态模型，ChatTongyi 会报 url error
LLM_MODEL_FAST=qwen-plus
# smart：选题 editor、写作 writer
LLM_MODEL_SMART=qwen3.7-max
# layout：排版 few-shot 长输出
LLM_MODEL_LAYOUT=qwen3.7-max
LLM_MAX_OUTPUT_TOKENS_LAYOUT=32768
# DashScope SDK 默认 300s；layout 长 HTML 建议 ≥600（须小于 LLM_INVOKE_TIMEOUT）
LLM_REQUEST_TIMEOUT_SECONDS=600
IMAGE_MODEL=wanx2.1-t2i-turbo
IMAGE_SIZE=1280*720

# ─── 腾讯云 COS（可选 MVP 后期）───
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-hongkong

# ─── 微信公众号 ───
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ORIGINAL_ID=
WECHAT_ACCOUNT_TYPE=subscription
WECHAT_ACCOUNT_SUBJECT=personal
WECHAT_CERTIFIED=false
WECHAT_IP_WHITELIST=

# ─── 通知（V1）───
WECOM_WEBHOOK_URL=

SECRET_KEY=

# ─── 前端（frontend/.env.development）───
# VITE_API_BASE_URL=http://localhost:8080/api/v1
