# 可选：本地手机微信扫码预览时，临时覆盖 .env.development 中的 PUBLIC_API_BASE_URL
#
# 1. 启动 ngrok：ngrok http 8080
# 2. 将下方域名改为 ngrok 分配的 HTTPS 地址
# 3. 写入 .env.development 并重启 api + worker：
#      PUBLIC_API_BASE_URL=https://xxxx.ngrok-free.dev
# 4. 预览结束后改回：PUBLIC_API_BASE_URL=http://localhost:8080
#
# 说明：日常本地看图/跑 Pipeline 不需要 ngrok；仅微信客户端需访问你本机 API 时才用。

PUBLIC_API_BASE_URL=https://xxxx.ngrok-free.dev
