# 生产服务器环境模板 — 在 CVM 上复制为 .env.development（项目约定服务器仍用此文件名）
# cp .env.production.example .env.development
# 填写 DASHSCOPE_API_KEY、微信密钥、SECRET_KEY、DATABASE_URL 等

ENV=production

API_PORT=8080
ADMIN_API_KEY=
SESSION_COOKIE_NAME=session_id
SESSION_TTL=24h
# HTTP 阶段可 false；HTTPS 备案后改 true
SESSION_SECURE=false
SESSION_SAME_SITE=Lax
CORS_ALLOWED_ORIGINS=
LOG_LEVEL=info
STUB_PIPELINE=false

WECHAT_READ_SOURCE_URL=https://fengyibin66.github.io/
# 与 Nginx server_name / 用户访问域名一致（HTTPS 推荐）
# 媒体 URL：https://yibinfeng.com/api/v1/public/media/{id}
PUBLIC_API_BASE_URL=https://yibinfeng.com

DATABASE_URL=mysql://wechat:CHANGE_ME@tcp(mysql:3306)/wechat_ai?parseTime=true&loc=UTC&charset=utf8mb4
REDIS_URL=redis://redis:6379/0

COLLECT_DAYS=2
COLLECT_MIN_ARTICLES=5

LLM_SERVICE_URL=http://llm-service:8090
LLM_INVOKE_TIMEOUT=10m
DASHSCOPE_API_KEY=
LLM_MODEL_FAST=qwen-plus
LLM_MODEL_SMART=qwen3.7-max
LLM_MODEL_LAYOUT=qwen3.7-max
LLM_MAX_OUTPUT_TOKENS_LAYOUT=32768
LLM_REQUEST_TIMEOUT_SECONDS=600
IMAGE_MODEL=wanx2.1-t2i-turbo
IMAGE_SIZE=1280*720

TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-hongkong

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ORIGINAL_ID=
WECHAT_ACCOUNT_TYPE=subscription
WECHAT_ACCOUNT_SUBJECT=personal
WECHAT_CERTIFIED=false
WECHAT_IP_WHITELIST=

WECOM_WEBHOOK_URL=
SECRET_KEY=

# 前端：frontend/.env.production → VITE_API_BASE_URL=/api/v1（Nginx 同源）
