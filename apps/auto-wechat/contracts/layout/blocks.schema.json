{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-wechat-tech.local/contracts/layout/blocks.schema.json",
  "title": "WeChatLayoutDocument",
  "description": "Layout Planner 输出契约：LLM 只编排 blocks，HTML/SVG 由 Go 模板渲染器生成",
  "type": "object",
  "required": ["title", "blocks"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 64 },
    "coverImageUrl": { "type": "string" },
    "layoutNotes": { "type": "string" },
    "blocks": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/block" }
    }
  },
  "$defs": {
    "block": {
      "oneOf": [
        { "$ref": "#/$defs/masthead" },
        { "$ref": "#/$defs/hero_svg" },
        { "$ref": "#/$defs/lead" },
        { "$ref": "#/$defs/section" },
        { "$ref": "#/$defs/news_item" },
        { "$ref": "#/$defs/divider" },
        { "$ref": "#/$defs/quote" },
        { "$ref": "#/$defs/figure" },
        { "$ref": "#/$defs/sources_footer" }
      ]
    },
    "masthead": {
      "type": "object",
      "required": ["type", "seriesTitle", "dateLabel"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "masthead" },
        "seriesTitle": { "type": "string" },
        "dateLabel": { "type": "string" },
        "topic": { "type": "string" }
      }
    },
    "hero_svg": {
      "type": "object",
      "required": ["type", "leadText", "tapHint"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "hero_svg" },
        "variant": { "enum": ["lead_expand"], "default": "lead_expand" },
        "leadText": { "type": "string", "maxLength": 200 },
        "tapHint": { "type": "string", "maxLength": 24 },
        "backgroundImageUrl": {
          "type": "string",
          "description": "须为微信素材库 URL（mmbiz.qpic.cn）；空则使用主题渐变"
        }
      }
    },
    "lead": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "lead" },
        "text": { "type": "string", "maxLength": 200 }
      }
    },
    "section": {
      "type": "object",
      "required": ["type", "heading"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "section" },
        "heading": { "type": "string" },
        "tag": { "type": "string" }
      }
    },
    "news_item": {
      "type": "object",
      "required": ["type", "summary", "sourceName", "sourceUrl"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "news_item" },
        "headline": { "type": "string", "maxLength": 80 },
        "summary": { "type": "string", "maxLength": 300 },
        "sourceName": { "type": "string" },
        "sourceUrl": { "type": "string", "format": "uri" }
      }
    },
    "divider": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "divider" }
      }
    },
    "quote": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "quote" },
        "text": { "type": "string", "maxLength": 200 }
      }
    },
    "figure": {
      "type": "object",
      "required": ["type", "imageUrl"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "figure" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string", "maxLength": 80 }
      }
    },
    "sources_footer": {
      "type": "object",
      "required": ["type", "sources"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "sources_footer" },
        "title": { "type": "string", "default": "参考来源" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    }
  }
}
