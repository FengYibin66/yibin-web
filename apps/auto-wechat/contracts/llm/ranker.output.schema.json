{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RankerOutput",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "title", "score"],
        "properties": {
          "url": { "type": "string" },
          "title": { "type": "string" },
          "score": { "type": "number" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
