# Admin password — change this before deploying
ADMIN_PASSWORD=change_me_before_deploy

# Paths (defaults work for local dev)
DB_PATH=../data/portal.db
UPLOADS_DIR=../uploads
PORT=3001
NODE_ENV=development

# CORS — client origin in dev (comma-separated for multiple origins)
CLIENT_ORIGIN=http://www.yibinfeng.com,http://localhost:5173
