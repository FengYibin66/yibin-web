# ──────────────────────────────────────────────────────────────
# Development overrides (URLs, flags — no secrets here)
# ──────────────────────────────────────────────────────────────
# Merged with .env.shared.local → .env.development (repo root)

NODE_ENV=development
ENV=development

# Portal (Hono)
PORT=3001
DB_PATH=../data/portal.db
UPLOADS_DIR=../uploads
CLIENT_ORIGIN=http://www.yibinfeng.com,http://localhost:5173

# Auto-Wechat API
API_PORT=8080
LOG_LEVEL=debug
SESSION_COOKIE_NAME=session_id
SESSION_TTL=24h
SESSION_SECURE=false
SESSION_SAME_SITE=Lax
STUB_PIPELINE=true
CORS_ALLOWED_ORIGINS=http://www.yibinfeng.com,http://localhost:5173,http://localhost:5174,http://mpauto.yibinfeng.com
PUBLIC_API_BASE_URL=http://localhost:8080
WECHAT_READ_SOURCE_URL=https://fengyibin66.github.io/
WECHAT_CALLBACK_URL=http://localhost:8080/api/v1/wechat/callback

# Dev: host MySQL mapped to 3307 (see apps/auto-wechat/docker-compose.dev.yml)
# Override in .env.shared.local if running API outside Docker:
# DATABASE_URL=mysql://wechat:PASSWORD@tcp(localhost:3307)/wechat_ai?parseTime=true&loc=UTC&charset=utf8mb4

REDIS_URL=redis://redis:6379/0

# LLM service
LLM_SERVICE_URL=http://llm-service:8090
LLM_INVOKE_TIMEOUT=10m
LLM_REQUEST_TIMEOUT_SECONDS=600
LLM_MODEL_FAST=qwen-plus
LLM_MODEL_SMART=qwen-max
LLM_MODEL_LAYOUT=qwen-max
LLM_MAX_OUTPUT_TOKENS_LAYOUT=32768
IMAGE_MODEL=wanx2.1-t2i-turbo
IMAGE_SIZE=1280*720

# WeChat metadata (non-secret)
WECHAT_ACCOUNT_TYPE=subscription
WECHAT_ACCOUNT_SUBJECT=personal
WECHAT_CERTIFIED=false
WECHAT_IP_WHITELIST=

# Tencent COS region (match your bucket)
COS_REGION=ap-beijing

COLLECT_DAYS=2
COLLECT_MIN_ARTICLES=5

PORTAL_DATABASE_URL=
