# 可选：手机微信扫码预览时，临时覆盖根目录 .env.development 中的 PUBLIC_API_BASE_URL
#
# 1. 启动 ngrok：ngrok http 8080
# 2. 将下方域名改为 ngrok 分配的 HTTPS 地址
# 3. 合并进 development 环境并重启 api + worker：
#      ENV_EXTRA=config/env.ngrok.example ./scripts/env-build.sh development
#      cd apps/auto-wechat && make dev-up
# 4. 预览结束后重新 ./scripts/env-build.sh development
#
# 说明：日常本地跑 Pipeline 不需要 ngrok；仅微信客户端需访问你本机 API 时才用。

PUBLIC_API_BASE_URL=https://xxxx.ngrok-free.dev
