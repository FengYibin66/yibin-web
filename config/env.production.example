# ──────────────────────────────────────────────────────────────
# Production overrides (URLs, flags — no secrets here)
# ──────────────────────────────────────────────────────────────
# Merged with .env.shared.local → .env.production (repo root + CVM)

NODE_ENV=production
ENV=production

# Portal (Hono)
PORT=3001
CLIENT_ORIGIN=https://www.yibinfeng.com

# Auto-Wechat API
API_PORT=8080
LOG_LEVEL=info
SESSION_COOKIE_NAME=session_id
SESSION_TTL=24h
SESSION_SECURE=true
SESSION_SAME_SITE=Lax
STUB_PIPELINE=false
CORS_ALLOWED_ORIGINS=https://www.yibinfeng.com,https://resume.yibinfeng.com,https://mpauto.yibinfeng.com
PUBLIC_API_BASE_URL=https://mpauto.yibinfeng.com
WECHAT_READ_SOURCE_URL=https://fengyibin66.github.io/
WECHAT_CALLBACK_URL=https://mpauto.yibinfeng.com/api/v1/wechat/callback

REDIS_URL=redis://redis:6379/0

# LLM service (Docker internal)
LLM_SERVICE_URL=http://llm-service:8090
LLM_INVOKE_TIMEOUT=10m
LLM_REQUEST_TIMEOUT_SECONDS=600
LLM_MODEL_FAST=qwen-plus
LLM_MODEL_SMART=qwen-max
LLM_MODEL_LAYOUT=qwen-max
LLM_MAX_OUTPUT_TOKENS_LAYOUT=32768
IMAGE_MODEL=wanx2.1-t2i-turbo
IMAGE_SIZE=1280*720

WECHAT_ACCOUNT_TYPE=subscription
WECHAT_ACCOUNT_SUBJECT=personal
WECHAT_CERTIFIED=false
WECHAT_IP_WHITELIST=

# Match CVM region (Beijing Lighthouse → ap-beijing)
COS_REGION=ap-beijing

COLLECT_DAYS=2
COLLECT_MIN_ARTICLES=5

PORTAL_DATABASE_URL=

SSL_CERT_PATH=/etc/letsencrypt/live/www.yibinfeng.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/www.yibinfeng.com/privkey.pem
