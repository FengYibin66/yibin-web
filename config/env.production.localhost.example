# Localhost overrides when running docker-compose.prod.yml on Mac (verify script)
CLIENT_ORIGIN=http://localhost,http://www.yibinfeng.com
SESSION_SECURE=false
STUB_PIPELINE=true
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost,http://www.yibinfeng.com,http://resume.yibinfeng.com,http://mpauto.yibinfeng.com
PUBLIC_API_BASE_URL=http://localhost:8080
WECHAT_CALLBACK_URL=http://localhost:8080/api/v1/wechat/callback
