# ──────────────────────────────────────────────────────────────
# Shared secrets & credentials (same across dev / production)
# ──────────────────────────────────────────────────────────────
# 1. cp config/env.shared.example → .env.shared.local
# 2. Fill all CHANGE_ME values in .env.shared.local (never commit)
# 3. ./scripts/env-build.sh development|production

# MySQL
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_PASSWORD=CHANGE_ME_WECHAT_PASSWORD
# env-build syncs password into DATABASE_URL automatically
DATABASE_URL=mysql://wechat:CHANGE_ME_WECHAT_PASSWORD@tcp(mysql:3306)/wechat_ai?parseTime=true&loc=UTC&charset=utf8mb4

# Portal admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Auto-Wechat API
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY
SECRET_KEY=CHANGE_ME_SECRET_KEY_32_CHARS_MIN

# LLM (Dashscope)
DASHSCOPE_API_KEY=CHANGE_ME_DASHSCOPE_API_KEY

# WeChat
WECHAT_APP_ID=CHANGE_ME_WECHAT_APP_ID
WECHAT_APP_SECRET=CHANGE_ME_WECHAT_APP_SECRET
WECHAT_ORIGINAL_ID=CHANGE_ME_WECHAT_ORIGINAL_ID

# Tencent Cloud COS
# Portal MVP 未使用；Phase 2 媒体上 CDN 时启用 — docs/specs/portal-media.md
TENCENT_SECRET_ID=CHANGE_ME_TENCENT_SECRET_ID
TENCENT_SECRET_KEY=CHANGE_ME_TENCENT_SECRET_KEY
COS_BUCKET=CHANGE_ME_BUCKET_NAME

# Optional
WECOM_WEBHOOK_URL=
