{
  "name": "yibin-web-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for yibinfeng.com projects",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev:portal": "pnpm --filter @yibin/portal dev",
    "dev:resume": "pnpm --filter @yibin/resume dev",
    "dev:wechat": "pnpm --filter @yibin/auto-wechat frontend:dev",
    "build:portal": "pnpm --filter @yibin/portal build",
    "build:resume": "pnpm --filter @yibin/resume build",
    "lint": "pnpm -r lint",
    "setup": "pnpm install"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
